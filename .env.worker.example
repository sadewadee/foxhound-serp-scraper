# =============================================================================
# .env.worker.example — Server B/C/D (Remote Worker)
# =============================================================================
# Copy to .env and fill in values:
#   cp .env.worker.example .env
#
# Then:
#   docker compose -f docker-compose.worker.yaml up -d
#
# Connect to Server A via Tailscale/WireGuard/VPN.
# Replace 100.x.x.1 with Server A's Tailscale IP.

# ── Remote PostgreSQL (Server A) ──
POSTGRES_DSN=postgres://serp:your_pg_password@100.x.x.1:5432/serp_scraper?sslmode=disable

# ── Remote Redis (Server A) ──
REDIS_ADDR=100.x.x.1:6379
REDIS_PASSWORD=your_redis_password

# ── Worker Config ──
WORKER_STAGE=contact              # contact | website | serp | all
WORKER_COUNT=20                   # concurrent workers (= browser tabs)

# ── Image ──
# IMAGE_TAG=main                  # ghcr.io tag (default: main)

# ── Proxy (optional, recommended for different IP range) ──
# PROXY_URL=socks5://user:pass@proxy.example.com:1080

# ── Email Validation (optional) ──
# MORDIBOUNCER_API_URL=https://mailexchange.kremlit.dev
# MORDIBOUNCER_SECRET=your_mordibouncer_secret

# ── Resource Limits ──
# WORKER_MEMORY=1g                # container memory limit (default: 1g)
# SHM_SIZE=512mb                  # shared memory for browser (default: 512mb)

# ── Ports ──
# METRICS_PORT=9091               # Prometheus metrics (default: 9091)

# ── Timezone ──
TZ=Asia/Jakarta
